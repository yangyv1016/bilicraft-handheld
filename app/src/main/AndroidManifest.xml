<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络：连接 MC 服务器 + 微软/Mojang 接口 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 应用内更新：下载 APK 后唤起系统安装器 -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- 常驻策略所需 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BilicraftHandheld">

        <activity
            android:name=".ui.WebViewActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!--
          桌面启动图标改由 activity-alias 承载：每个 alias = 一个可选图标。
          切换逻辑见 AppIconManager，通过 PackageManager 启停 alias，保证任意时刻恰好一个启用。
          下面标记区内的 alias 由 Gradle 任务 syncAppIcons 依据 icons/*.png 自动生成，勿手改。
        -->
        <!-- APP-ICON AUTO-GENERATED START -->
        <activity-alias
            android:name=".ui.alias.Icon"
            android:targetActivity=".ui.MainActivity"
            android:icon="@drawable/app_icon_icon"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".ui.alias.Bihoyo"
            android:targetActivity=".ui.MainActivity"
            android:icon="@drawable/app_icon_bihoyo"
            android:label="@string/app_name"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <!-- APP-ICON AUTO-GENERATED END -->

        <!-- 前台 Service：锁屏保持 MC 连接（dataSync 类型，配合持久通知） -->
        <service
            android:name=".service.ConnectionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 更新包安装：通过 FileProvider 把私有目录 APK 以 content:// 授权给系统安装器 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>